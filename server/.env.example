TRANSCRIPTION_AUDIO_MAX_BYTES=26214400
PROCESSING_JOB_MAX_ATTEMPTS=5
PROCESSING_JOB_LEASE_SECONDS=600
PROCESSING_WORKER_IDLE_SECONDS=3
