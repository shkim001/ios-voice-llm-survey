OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_ANALYSIS_MODEL=gpt-4o
OPENAI_REQUEST_TIMEOUT_SECONDS=180

# Durable processing intake and worker settings.
