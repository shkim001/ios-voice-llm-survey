MYSQL_HOST=35.223.64.86
MYSQL_PORT=3306
MYSQL_USER=app_user
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=survey

# Optional: reject requests without this header (set empty to disable)
API_KEY=

# Complete session package storage. Use an absolute path on the VM for production.
SURVEY_PACKAGE_STORAGE_DIR=./survey_session_packages
SESSION_JSON_MAX_BYTES=26214400

AUDIO_MAX_BYTES=209715200

# Server-only OpenAI processing. Never put this key in the iOS app.
